venv/
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/
legacy_tooling_report.json
legacy_tooling_report.md

# VitePress
docs/.vitepress/cache/
docs/.vitepress/dist/

# Misc
*.tmp
*.bak
*.orig
